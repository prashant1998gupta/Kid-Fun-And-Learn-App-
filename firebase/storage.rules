rules_version = '2';

// KidVerse Storage rules.
// - Curriculum/media assets: world-readable, admin-writable.
// - Avatar renders / user uploads: private to the owning parent, size-capped,
//   image-only (defense against arbitrary uploads).
service firebase.storage {
  match /b/{bucket}/o {

    match /content/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }

    match /users/{uid}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
